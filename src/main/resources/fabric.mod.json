{
	"schemaVersion": 1,
	"id": "gibcoins",
	"version": "${version}",
	"name": "GibCoins",
	"description": "Addon for Hypixel Skyblock. May get you banned.",
	"authors": [
		"/"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/gibcoins/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "com.github.tytoyos.gibcoins.GibCoins::onInitializeClient",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"gibcoins.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.1",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}